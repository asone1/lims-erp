# =========================================================================
# 【架構規範】App Engine 搬遷特別防線 (絕對禁止進版控)
# =========================================================================
app.yaml                # 遵守: 治理層防護 - 阻絕 GCP App Engine 正式環境組態外洩
cron.yaml               # 阻絕排程排班敏感資訊
queue.yaml              # 阻絕 Task Queue 敏感資訊

# =========================================================================
# 【核心資安】GCP 憑證與敏感資料 (絕對不能進版控)
# =========================================================================
gcp-key.json
*.pem
*.key
*.p12
.env                    # 遵守: 絕對禁止硬編碼 - 本地環境變數隔離

# =========================================================================
# 【基礎設施】Docker 本地開發暫存資料隔離
# =========================================================================
*/data/                 # 遵守: 預期失敗 - 隔離本地 Docker 容器掛載的資料庫實體檔案
*.local.yml             # 允許工程師本地自訂的 docker-compose 覆寫檔

# =========================================================================
# Maven & Quarkus 後端建置輸出
# =========================================================================
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
release.properties
.flattened-pom.xml
/.quarkus/cli/plugins/

# =========================================================================
# 【前端 React】Node.js 相關建置與套件暫存
# =========================================================================
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# =========================================================================
# IDEs & 編輯器暫存 (Eclipse, IntelliJ, NetBeans, VS Code, Vim)
# =========================================================================
.project
.classpath
.settings/
bin/
.idea
*.ipr
*.iml
*.iws
nb-configuration.xml
.vscode
.factorypath
*.swp
*.swo

# =========================================================================
# 作業系統與系統補丁暫存
# =========================================================================
.DS_Store
*.orig
*.rej